# Connection string PostgreSQL.
# Lokal (lewat Docker, lihat README): postgresql://postgres:postgres@localhost:5432/task_manager
# Vercel Postgres (Neon/Supabase via Marketplace): otomatis diisi Vercel saat
# kamu connect database-nya, formatnya kira-kira:
# postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=

# Secret untuk menandatangani session JWT (Auth.js v5).
# Generate dengan: openssl rand -base64 33
# WAJIB diisi sebelum aplikasi bisa login. Jangan dipakai ulang antar
# environment (lokal vs production harus beda value).
AUTH_SECRET=
